# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/

# ─── Next.js ─────────────────────────────────────────────────────────────────
.next/
out/
build/

# ─── Database (local SQLite — never commit real data) ────────────────────────
prisma/*.db
prisma/*.db-journal
prisma/*.db-shm
prisma/*.db-wal

# ─── Environment variables (may contain secrets) ─────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ─── macOS ───────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Misc ────────────────────────────────────────────────────────────────────
.vercel
*.tsbuildinfo
next-env.d.ts
